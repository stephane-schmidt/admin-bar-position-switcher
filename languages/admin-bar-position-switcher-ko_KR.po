msgstr "바"

msgid "Move the toolbar to the top or bottom"
msgstr "툴바를 상단 또는 하단으로 이동"

msgid "WordPress logo"
msgstr "WordPress 로고"

msgid "Site name"
msgstr "사이트 이름"


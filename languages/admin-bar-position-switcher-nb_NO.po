msgid "Admin Bar Position Switcher"
msgstr ""

msgid "https://wordpress.org/plugins/admin-bar-position-switcher/"
msgstr ""

msgid "Moves the WordPress toolbar to the bottom of the screen on the front end, with a one-click button to flip it between top and bottom. The choice is remembered per browser."
msgstr "Flytter WordPress-verktøylinjen til bunnen av skjermen på nettstedet, med en ettklikksknapp for å veksle mellom topp og bunn. Valget huskes per nettleser."

msgid "Stéphane Schmidt"
msgstr ""

msgid "https://alveo.design"
msgstr ""

msgid "Bar"
msgstr "Linje"

msgid "Move the toolbar to the top or bottom"
msgstr "Flytt verktøylinjen til toppen eller bunnen"

msgid "Admin Bar Position"
msgstr "Plassering av administrasjonslinjen"

msgid "Settings"
msgstr "Innstillinger"

msgid "Default position"
msgstr "Standardplassering"

msgid "Switch button"
msgstr "Bytteknapp"

msgid "Button label"
msgstr "Knappetekst"

msgid "Remember the choice"
msgstr "Husk valget"

msgid "Match the page color"
msgstr "Tilpass sidefargen"

msgid "Elementor compatibility"
msgstr "Elementor-kompatibilitet"

msgctxt "settings page title"
msgid "Admin Bar Position"
msgstr "Plassering av administrasjonslinjen"

msgid "Choose where the WordPress toolbar sits on the front end. Visitors who are not logged in never see it."
msgstr "Velg hvor WordPress-verktøylinjen skal plasseres på nettstedet. Besøkende som ikke er logget inn, ser den aldri."

msgid "Bottom"
msgstr "Nederst"

msgid "Top (WordPress default)"
msgstr "Øverst (WordPress-standard)"

msgid "Where the toolbar appears before the visitor flips it."
msgstr "Hvor verktøylinjen vises før den besøkende bytter plassering."

msgid "Show the floating button to move the toolbar top/bottom."
msgstr "Vis den flytende knappen for å flytte verktøylinjen øverst/nederst."

msgid "Text shown next to the ↕ arrow on the button. Leave empty for the default."
msgstr "Tekst som vises ved siden av ↕-pilen på knappen. La stå tom for standardverdien."

msgid "Remember each browser's choice (stored locally in the browser)."
msgstr "Husk hver nettlesers valg (lagres lokalt i nettleseren)."

msgid "Tint the button with the main color of each page (falls back to the default dark button when no color is found)."
msgstr "Fargelegg knappen med hovedfargen på hver side (går tilbake til den mørke standardknappen når ingen farge blir funnet)."

msgid "Adjust Elementor sticky headers so they line up with the toolbar."
msgstr "Juster faste Elementor-topptekster slik at de flukter med verktøylinjen."

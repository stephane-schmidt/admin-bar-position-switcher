msgstr "חיפוש"

msgid "User menu (My account)"
msgstr "תפריט משתמש (החשבון שלי)"

msgid "Admin Bar Position"
msgstr "מיקום סרגל הניהול"

msgid "Settings"
msgstr "הגדרות"

msgid "Default position"
msgstr "מיקום ברירת מחדל"

msgid "Switch button"
msgstr "כפתור החלפה"

msgid "Button label"
msgstr "תווית הכפתור"

msgid "Remember the choice"
msgstr "זכירת הבחירה"

msgid "Match the page color"
msgstr "התאמה לצבע העמוד"

msgid "Elementor compatibility"
msgstr "תאימות ל-Elementor"

msgid "Appearance & items"
msgstr "מראה ופריטים"

msgid "Toolbar background"
msgstr "רקע סרגל הכלים"

msgid "Hide toolbar items"
msgstr "הסתרת פריטים בסרגל הכלים"

msgid "These options change how the toolbar looks on the front end."
msgstr "אפשרויות אלה משנות את מראה סרגל הכלים בצד הקדמי."

msgctxt "settings page title"
msgid "Admin Bar Position"
msgstr "מיקום סרגל הניהול"

msgid "Choose where the WordPress toolbar sits on the front end. Visitors who are not logged in never see it."
msgstr "בחר היכן ימוקם סרגל הכלים של WordPress בצד הקדמי. מבקרים שאינם מחוברים לעולם לא רואים אותו."

msgid "Bottom"
msgstr "למטה"

msgid "Top (WordPress default)"
msgstr "למעלה (ברירת המחדל של WordPress)"

msgid "Where the toolbar appears before the visitor flips it."
msgstr "היכן מופיע סרגל הכלים לפני שהמבקר מעביר אותו."

msgid "Show the floating button to move the toolbar top/bottom."
msgstr "הצגת הכפתור הצף להעברת סרגל הכלים למעלה/למטה."

msgid "Text shown next to the ↕ arrow on the button. Leave empty for the default."
msgstr "טקסט המוצג ליד החץ ↕ על הכפתור. השאר ריק לברירת המחדל."

msgid "Remember each browser's choice (stored locally in the browser)."
msgstr "זכירת הבחירה של כל דפדפן (נשמרת מקומית בדפדפן)."

msgid "Tint the button with the main color of each page (falls back to the default dark button when no color is found)."
msgstr "צביעת הכפתור בצבע הראשי של כל עמוד (חוזר לכפתור הכהה של ברירת המחדל כאשר לא נמצא צבע)."

msgid "Adjust Elementor sticky headers so they line up with the toolbar."
msgstr "התאמת כותרות דביקות של Elementor כך שיתיישרו עם סרגל הכלים."

msgid "Colorize the toolbar background"
msgstr "צביעת רקע סרגל הכלים"

msgid "The text color adjusts automatically for readability."
msgstr "צבע הטקסט מותאם אוטומטית לקריאות."

msgid "Tick the items you want to hide from the front-end toolbar."
msgstr "סמן את הפריטים שברצונך להסתיר מסרגל הכלים בצד הקדמי."

msgid "Support the author"
msgstr "תמכו במפתח"

msgid "This little plugin is free and open source. If it earned a spot on your screen, you can support its development — or simply say hello."
msgstr "התוסף הקטן הזה חינמי ובקוד פתוח. אם מצא לו מקום על המסך שלכם, אתם מוזמנים לתמוך בפיתוח שלו — או פשוט לומר שלום."

msgid "Buy me a coffee"
msgstr "קנו לי קפה"

msgid "Available for freelance work"
msgstr "פנוי לעבודות פרילנס"

msgid "Auto-hide the button"
msgstr "הסתרה אוטומטית של הכפתור"

msgid "Let the button drift away after a few seconds without use, and bring it back when the pointer moves over the toolbar."
msgstr "גורם לכפתור להיעלם בהדרגה לאחר כמה שניות ללא שימוש, ומחזיר אותו כשהסמן עובר מעל סרגל הכלים."

msgid "Off by default: the button stays visible."
msgstr "כבוי כברירת מחדל: הכפתור נשאר גלוי."

msgid "Toolbar color"
msgstr "צבע סרגל הכלים"

msgid "Default"
msgstr "ברירת מחדל"

msgid "Color picker in the toolbar"
msgstr "בוחר צבעים בסרגל הכלים"

msgid "Add a \"Bar\" item to the toolbar so administrators can recolor it with one of the site's dominant colors, detected from your logo and theme."
msgstr "הוספת פריט \"Bar\" לסרגל הכלים, כדי לאפשר למנהלי האתר לצבוע אותו מחדש באחד מהצבעים הדומיננטיים של האתר, המזוהים אוטומטית מהלוגו ומערכת העיצוב שלך."

msgid "Auto-hide the toolbar"
msgstr "הסתרה אוטומטית של סרגל הכלים"

msgid "Hide the toolbar off-screen like the macOS Dock: it glides back when the pointer comes within 150 pixels of its edge, or when it receives keyboard focus."
msgstr "הסתרת סרגל הכלים אל מחוץ למסך, בדומה ל-macOS Dock: הוא מחליק חזרה כאשר הסמן מתקרב למרחק של 150 פיקסלים מקצהו, או כאשר הוא מקבל מיקוד מקלדת."

msgid "Off by default: the toolbar stays visible at all times."
msgstr "כבוי כברירת מחדל: סרגל הכלים נשאר גלוי בכל עת."

msgid "Back-office menu"
msgstr "תפריט הניהול"

msgid "Give the left admin menu your own colors: pick a background per item (the text stays readable automatically) and add spacers between groups."
msgstr "תנו לתפריט הניהול השמאלי צבעים משלכם: בחרו רקע לכל פריט (הטקסט נשאר קריא אוטומטית) והוסיפו מרווחים בין קבוצות."

msgid "Menu items"
msgstr "פריטי תפריט"

msgid "Color"
msgstr "צבע"

msgid "Spacer before"
msgstr "מרווח לפני"

msgid "Dim the other items"
msgstr "עמעום שאר הפריטים"

msgid "Fade the menu items that have no custom color; they light up again on hover or when active."
msgstr "מעמעם פריטי תפריט ללא צבע מותאם; הם שבים ומוארים במעבר עכבר או כשהם פעילים."

msgid "Admin Bar"
msgstr "סרגל ניהול"

msgid "Menu order"
msgstr "סדר התפריט"

msgid "Toolbar order"
msgstr "סדר סרגל הכלים"

msgid "Apply this custom order"
msgstr "החלת סדר מותאם זה"

msgid "Drag the items into the order you want."
msgstr "גררו את הפריטים לסדר הרצוי."

msgid "Menu side"
msgstr "צד התפריט"

msgid "Left (WordPress default)"
msgstr "שמאל (ברירת המחדל של וורדפרס)"

msgid "Right"
msgstr "ימין"

msgid "Show floating tabs beside the back-office menu to hide it or flip it between left and right (remembered per browser)."
msgstr "הצגת לשוניות צפות לצד תפריט הניהול כדי להסתיר אותו או להעבירו בין שמאל לימין (נשמר לכל דפדפן)."

msgid "Auto-hide the menu"
msgstr "הסתרה אוטומטית של התפריט"

msgid "Hide the back-office menu off-screen like the macOS Dock: it glides back when the pointer comes within 150 pixels of its edge."
msgstr "הסתרת תפריט הניהול אל מחוץ למסך, בדומה ל-macOS Dock: הוא מחליק חזרה כשהסמן מתקרב ל-150 פיקסלים מקצהו."

msgid "Off by default: the menu stays visible at all times."
msgstr "כבוי כברירת מחדל: התפריט נשאר גלוי תמיד."

msgid "Move the menu to the left or right"
msgstr "העברת התפריט שמאלה או ימינה"

msgid "Menu"
msgstr "תפריט"

msgid "Hide or show the menu"
msgstr "הסתרה או הצגה של התפריט"

msgid "Space after"
msgstr "רווח אחרי"

msgid "Drag the handle to reorder the menu; the color and the space after apply to each item."
msgstr "גררו את הידית כדי לסדר מחדש את התפריט; הצבע והרווח שאחרי חלים על כל פריט."

msgid "Make the left admin menu yours: drag the items into your own order, give each one a background color (the text stays readable automatically) and add space after an item to build groups."
msgstr "הפכו את תפריט הניהול השמאלי לשלכם: גררו את הפריטים לסדר משלכם, תנו לכל פריט צבע רקע (הטקסט נשאר קריא אוטומטית) והוסיפו רווח אחרי פריט כדי ליצור קבוצות."

msgid "Color and reorder the back-office menu, dock it away like the macOS Dock, and hide the toolbar items you never use. One payment of $15, yours for life."
msgstr "צבעו וסדרו מחדש את תפריט הניהול, עגנו אותו כמו ה-Dock של macOS, והסתירו פריטי סרגל שאינכם משתמשים בהם. תשלום חד-פעמי של ‎15 $‎, שלכם לתמיד."

msgid "Discover SwitchMyBar Pro"
msgstr "גלו את SwitchMyBar Pro"

msgstr "Käyttäjävalikko (Oma tili)"

msgid "Admin Bar Position"
msgstr "Työkalupalkin sijainti"

msgid "Settings"
msgstr "Asetukset"

msgid "Default position"
msgstr "Oletussijainti"

msgid "Switch button"
msgstr "Vaihtopainike"

msgid "Button label"
msgstr "Painikkeen teksti"

msgid "Remember the choice"
msgstr "Muista valinta"

msgid "Match the page color"
msgstr "Sovita sivun väriin"

msgid "Elementor compatibility"
msgstr "Elementor-yhteensopivuus"

msgid "Appearance & items"
msgstr "Ulkoasu ja kohteet"

msgid "Toolbar background"
msgstr "Työkalupalkin tausta"

msgid "Hide toolbar items"
msgstr "Piilota työkalupalkin kohteet"

msgid "These options change how the toolbar looks on the front end."
msgstr "Nämä asetukset muuttavat työkalupalkin ulkoasua sivuston julkisella puolella."

msgctxt "settings page title"
msgid "Admin Bar Position"
msgstr "Työkalupalkin sijainti"

msgid "Choose where the WordPress toolbar sits on the front end. Visitors who are not logged in never see it."
msgstr "Valitse, missä WordPress-työkalupalkki sijaitsee sivuston julkisella puolella. Kirjautumattomat kävijät eivät näe sitä koskaan."

msgid "Bottom"
msgstr "Alareuna"

msgid "Top (WordPress default)"
msgstr "Yläreuna (WordPressin oletus)"

msgid "Where the toolbar appears before the visitor flips it."
msgstr "Missä työkalupalkki näkyy, ennen kuin kävijä vaihtaa sen paikkaa."

msgid "Show the floating button to move the toolbar top/bottom."
msgstr "Näytä kelluva painike, jolla työkalupalkin voi siirtää ylä- tai alareunaan."

msgid "Text shown next to the ↕ arrow on the button. Leave empty for the default."
msgstr "Painikkeessa ↕-nuolen vieressä näkyvä teksti. Jätä tyhjäksi käyttääksesi oletusta."

msgid "Remember each browser's choice (stored locally in the browser)."
msgstr "Muista kunkin selaimen valinta (tallennetaan paikallisesti selaimeen)."

msgid "Tint the button with the main color of each page (falls back to the default dark button when no color is found)."
msgstr "Sävytä painike kunkin sivun pääväriin (palautuu oletusarvoiseen tummaan painikkeeseen, jos väriä ei löydy)."

msgid "Adjust Elementor sticky headers so they line up with the toolbar."
msgstr "Säädä Elementorin kiinnittyviä ylätunnisteita niin, että ne asettuvat linjaan työkalupalkin kanssa."

msgid "Colorize the toolbar background"
msgstr "Väritä työkalupalkin tausta"

msgid "The text color adjusts automatically for readability."
msgstr "Tekstin väri säätyy automaattisesti luettavuuden takaamiseksi."

msgid "Tick the items you want to hide from the front-end toolbar."
msgstr "Valitse kohteet, jotka haluat piilottaa sivuston julkisen puolen työkalupalkista."

msgid "Support the author"
msgstr "Tue tekijää"

msgid "This little plugin is free and open source. If it earned a spot on your screen, you can support its development — or simply say hello."
msgstr "Tämä pieni lisäosa on ilmainen ja avoimen lähdekoodin. Jos se ansaitsi paikkansa näytölläsi, voit tukea sen kehitystä — tai vain sanoa hei."

msgid "Buy me a coffee"
msgstr "Tarjoa minulle kahvit"

msgid "Available for freelance work"
msgstr "Käytettävissä freelance-työhön"

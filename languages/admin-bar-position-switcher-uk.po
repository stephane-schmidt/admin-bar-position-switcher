msgid "Admin Bar Position Switcher"
msgstr ""

msgid "https://wordpress.org/plugins/admin-bar-position-switcher/"
msgstr ""

msgid "Moves the WordPress toolbar to the bottom of the screen on the front end, with a one-click button to flip it between top and bottom. The choice is remembered per browser."
msgstr "Переміщує панель інструментів WordPress донизу екрана у зовнішній частині сайту, з кнопкою для перемикання між верхом і низом одним клацанням. Вибір запам'ятовується для кожного браузера."

msgid "Stéphane Schmidt"
msgstr ""

msgid "https://alveo.design"
msgstr ""

msgid "Bar"
msgstr "Панель"

msgid "Move the toolbar to the top or bottom"
msgstr "Перемістити панель інструментів угору або вниз"

msgid "WordPress logo"
msgstr "Логотип WordPress"

msgid "Site name"
msgstr "Назва сайту"

msgid "Customize"
msgstr "Персоналізувати"

msgid "Updates"
msgstr "Оновлення"

msgid "Comments"
msgstr "Коментарі"


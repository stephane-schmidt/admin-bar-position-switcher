msgstr "Меню пользователя (Мой аккаунт)"

msgid "Admin Bar Position"
msgstr "Положение панели администратора"

msgid "Settings"
msgstr "Настройки"

msgid "Default position"
msgstr "Положение по умолчанию"

msgid "Switch button"
msgstr "Кнопка переключения"

msgid "Button label"
msgstr "Надпись на кнопке"

msgid "Remember the choice"
msgstr "Запоминать выбор"

msgid "Match the page color"
msgstr "Подстраивать под цвет страницы"

msgid "Elementor compatibility"
msgstr "Совместимость с Elementor"

msgid "Appearance & items"
msgstr "Внешний вид и элементы"

msgid "Toolbar background"
msgstr "Фон панели инструментов"

msgid "Hide toolbar items"
msgstr "Скрыть элементы панели инструментов"

msgid "These options change how the toolbar looks on the front end."
msgstr "Эти параметры меняют внешний вид панели инструментов на внешней части сайта."

msgctxt "settings page title"
msgid "Admin Bar Position"
msgstr "Положение панели администратора"

msgid "Choose where the WordPress toolbar sits on the front end. Visitors who are not logged in never see it."
msgstr "Выберите, где располагается панель инструментов WordPress на внешней части сайта. Посетители, не вошедшие в систему, её не видят."

msgid "Bottom"
msgstr "Внизу"

msgid "Top (WordPress default)"
msgstr "Вверху (по умолчанию в WordPress)"

msgid "Where the toolbar appears before the visitor flips it."
msgstr "Где появляется панель инструментов до того, как посетитель её переключит."

msgid "Show the floating button to move the toolbar top/bottom."
msgstr "Показывать плавающую кнопку для перемещения панели инструментов вверх/вниз."

msgid "Text shown next to the ↕ arrow on the button. Leave empty for the default."
msgstr "Текст, отображаемый рядом со стрелкой ↕ на кнопке. Оставьте пустым для значения по умолчанию."

msgid "Remember each browser's choice (stored locally in the browser)."
msgstr "Запоминать выбор для каждого браузера (сохраняется локально в браузере)."

msgid "Tint the button with the main color of each page (falls back to the default dark button when no color is found)."
msgstr "Окрашивать кнопку в основной цвет каждой страницы (возвращается к тёмной кнопке по умолчанию, если цвет не найден)."

msgid "Adjust Elementor sticky headers so they line up with the toolbar."
msgstr "Подстраивать закреплённые шапки Elementor, чтобы они совпадали с панелью инструментов."

msgid "Colorize the toolbar background"
msgstr "Окрашивать фон панели инструментов"

msgid "The text color adjusts automatically for readability."
msgstr "Цвет текста автоматически подстраивается для читаемости."

msgid "Tick the items you want to hide from the front-end toolbar."
msgstr "Отметьте элементы, которые вы хотите скрыть из панели инструментов на внешней части сайта."

msgid "Support the author"
msgstr "Поддержать автора"

msgid "This little plugin is free and open source. If it earned a spot on your screen, you can support its development — or simply say hello."
msgstr "Этот маленький плагин бесплатный и с открытым исходным кодом. Если он нашёл своё место на вашем экране, вы можете поддержать его развитие — или просто поздороваться."

msgid "Buy me a coffee"
msgstr "Угостить меня кофе"

msgid "Available for freelance work"
msgstr "Открыт для фриланс-заказов"

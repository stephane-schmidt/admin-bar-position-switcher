msgstr "Bară"

msgid "Move the toolbar to the top or bottom"
msgstr "Mută bara de instrumente sus sau jos"

msgid "WordPress logo"
msgstr "Logo WordPress"

msgid "Site name"
msgstr "Numele sitului"

msgid "Customize"
msgstr "Personalizează"

msgid "Updates"
msgstr "Actualizări"

msgid "Comments"
msgstr "Comentarii"

msgid "New"
msgstr "Nou"

msgid "Search"
msgstr "Caută"


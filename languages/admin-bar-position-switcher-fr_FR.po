msgid "https://alveo.design"
msgstr ""

#: includes/class-abps-plugin.php:150 includes/class-abps-settings.php:239
msgid "Bar"
msgstr "Barre"

#: includes/class-abps-plugin.php:155
msgid "Move the toolbar to the top or bottom"
msgstr "Déplacer la barre d'outils en haut ou en bas"

#: includes/class-abps-settings.php:71 includes/class-abps-settings.php:72
msgid "Admin Bar Position"
msgstr "Position de la barre d'administration"

#: includes/class-abps-settings.php:87
msgid "Settings"
msgstr "Réglages"

#: includes/class-abps-settings.php:115
msgid "Default position"
msgstr "Position par défaut"

#: includes/class-abps-settings.php:123
msgid "Switch button"
msgstr "Bouton de bascule"

#: includes/class-abps-settings.php:131
msgid "Button label"
msgstr "Libellé du bouton"

#: includes/class-abps-settings.php:139
msgid "Remember the choice"
msgstr "Mémoriser le choix"

#: includes/class-abps-settings.php:147
msgid "Match the page color"
msgstr "S'adapter à la couleur de la page"

#: includes/class-abps-settings.php:155
msgid "Elementor compatibility"
msgstr "Compatibilité Elementor"

#: includes/class-abps-settings.php:193
msgctxt "settings page title"
msgid "Admin Bar Position"
msgstr "Position de la barre d'administration"

#: includes/class-abps-settings.php:194
msgid ""
"Choose where the WordPress toolbar sits on the front end. Visitors who are "
"not logged in never see it."
msgstr ""
"Choisissez où se place la barre d'outils WordPress sur le site public. Les "
"visiteurs non connectés ne la voient jamais."

#: includes/class-abps-settings.php:213
msgid "Bottom"
msgstr "En bas"

#: includes/class-abps-settings.php:214
msgid "Top (WordPress default)"
msgstr "En haut (par défaut WordPress)"

#: includes/class-abps-settings.php:216
msgid "Where the toolbar appears before the visitor flips it."
msgstr ""
"L'endroit où apparaît la barre d'outils avant que le visiteur ne la bascule."

#: includes/class-abps-settings.php:228
msgid "Show the floating button to move the toolbar top/bottom."
msgstr ""
"Afficher le bouton flottant pour déplacer la barre d'outils en haut ou en "
"bas."

#: includes/class-abps-settings.php:240
msgid ""
"Text shown next to the ↕ arrow on the button. Leave empty for the default."
msgstr ""
"Texte affiché à côté de la flèche ↕ sur le bouton. Laisser vide pour la "
"valeur par défaut."

#: includes/class-abps-settings.php:252
msgid "Remember each browser's choice (stored locally in the browser)."
msgstr ""
"Mémoriser le choix de chaque navigateur (stocké localement dans le "
"navigateur)."

#: includes/class-abps-settings.php:265
msgid ""
"Tint the button with the main color of each page (falls back to the default "
"dark button when no color is found)."
msgstr ""
"Teinter le bouton avec la couleur principale de chaque page (repli sur le "
"bouton sombre par défaut si aucune couleur n'est trouvée)."

#: includes/class-abps-settings.php:278
msgid "Adjust Elementor sticky headers so they line up with the toolbar."
msgstr ""
"Ajuster les en-têtes collants d'Elementor pour qu'ils s'alignent sur la "
"barre d'outils."

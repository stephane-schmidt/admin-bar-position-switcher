#. Description of the plugin
#: admin-bar-position-switcher.php
msgid ""
"Moves the WordPress toolbar to the bottom of the screen on the front end, "
"with a one-click button to flip it between top and bottom. The choice is "
"remembered per browser."
msgstr ""
"Déplace la barre d'outils WordPress en bas de l'écran sur le site public, "
"avec un bouton pour la basculer en un clic entre le haut et le bas. Le choix "
"est mémorisé par navigateur."

#. Author of the plugin
#: admin-bar-position-switcher.php
msgid "Stéphane Schmidt"
msgstr ""

#. Author URI of the plugin
